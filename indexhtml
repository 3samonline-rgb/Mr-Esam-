<!DOCTYPE html>
<html lang="no" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Pris App by Mr. Intl</title>
    <style>
        * { box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #f1f2f6; margin: 0; padding: 15px; }
        .container { width: 100%; max-width: 450px; margin: auto; background: white; padding: 25px 15px; border-radius: 20px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); text-align: center; }
        h1 { color: #1e272e; font-size: 26px; margin: 0 0 5px 0; font-weight: 800; }
        .subtitle { color: #27ae60; font-size: 13px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; margin-bottom: 25px; }
        
        .input-group { background: #f8fafc; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #e2e8f0; text-align: left; }
        label { font-size: 12px; font-weight: bold; color: #7f8c8d; display: block; margin-bottom: 5px; }
        input[type="text"], input[type="number"] { width: 100%; padding: 12px; border: 2px solid #e1e8ed; border-radius: 8px; font-size: 15px; background: white; margin-bottom: 10px; }
        input:focus { border-color: #27ae60; outline: none; }
        
        .btn { width: 100%; background: #27ae60; color: white; padding: 14px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 12px rgba(39, 174, 96, 0.2); }
        .btn:active { transform: scale(0.98); }
        
        .search-box { width: 100%; padding: 12px; margin: 20px 0 10px 0; border: 2px solid #27ae60; border-radius: 8px; font-size: 15px; }
        
        h3 { text-align: left; color: #2c3e50; margin: 20px 0 10px 0; font-size: 16px; border-bottom: 2px solid #f1f2f6; padding-bottom: 5px; }
        .product-list { text-align: left; max-height: 300px; overflow-y: auto; }
        .product-item { background: #f8fafc; padding: 12px; border-radius: 8px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; border-left: 4px solid #27ae60; }
        .prod-info { flex-grow: 1; padding-right: 10px; }
        .prod-name { font-weight: 600; color: #2c3e50; font-size: 15px; }
        .prod-url { font-size: 11px; color: #95a5a6; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; }
        .prod-price { font-weight: 800; color: #eb4d4b; font-size: 18px; white-space: nowrap; }
        .delete-btn { background: #ff7675; color: white; border: none; padding: 5px 8px; border-radius: 4px; font-size: 11px; cursor: pointer; margin-left: 10px; }
    </style>
</head>
<body>

<div class="container">
    <h1>Pris App</h1>
    <div class="subtitle">by Mr. Intl (Offline Mode)</div>
    
    <div class="input-group">
        <label>Produktnavn (اسم المنتج)</label>
        <input type="text" id="pName" placeholder="F.eks. Tomater 1kg">
        
        <label>Pris i kr (السعر)</label>
        <input type="number" id="pPrice" placeholder="0.00">
        
        <label>Produkt-URL / Lenke (رابط المنتج - اختياري)</label>
        <input type="text" id="pUrl" placeholder="https://varedatabase.no/...">
        
        <button class="btn" onclick="saveProduct()">Lagre Produkt (حفظ بالهاتف)</button>
    </div>

    <input type="text" id="searchInp" class="search-box" placeholder="Søk etter produkt (بحث سريع)..." oninput="displayProducts()">

    <h3>Lagrede Produkter (المنتجات المحفوظة في هاتفك)</h3>
    <div class="product-list" id="productList">
        </div>
</div>

<script>
    // دالة لجلب المنتجات المخزنة في ذاكرة الهاتف عند فتح التطبيق
    let products = JSON.parse(localStorage.getItem('mr_intl_prices')) || [];

    // دالة لحفظ منتج جديد في ذاكرة الهاتف
    function saveProduct() {
        const name = document.getElementById('pName').value.strip;
        const price = document.getElementById('pPrice').value;
        const url = document.getElementById('pUrl').value || 'Ingen lenke';

        if (!document.getElementById('pName').value || !price) {
            alert('Vennligst fyll ut både navn og pris!');
            return;
        }

        const newProduct = {
            id: Date.now(),
            name: document.getElementById('pName').value,
            price: parseFloat(price).toFixed(2),
            url: url
        };

        products.unshift(newProduct); // إضافة المنتج الجديد في أول القائمة
        localStorage.setItem('mr_intl_prices', JSON.stringify(products)); // تخزينه في الهاتف
        
        // تفريغ الحقول بعد الحفظ
        document.getElementById('pName').value = '';
        document.getElementById('pPrice').value = '';
        document.getElementById('pUrl').value = '';
        
        displayProducts();
    }

    // دالة لحذف منتج من ذاكرة الهاتف
    function deleteProduct(id) {
        if(confirm('Vil du slette dette produktet?')) {
            products = products.filter(p => p.id !== id);
            localStorage.setItem('mr_intl_prices', JSON.stringify(products));
            displayProducts();
        }
    }

    // دالة لعرض المنتجات والبحث بينها (تعمل 100% بدون إنترنت)
    function displayProducts() {
        const listDiv = document.getElementById('productList');
        const searchTerm = document.getElementById('searchInp').value.toLowerCase();
        listDiv.innerHTML = '';

        const filtered = products.filter(p => p.name.toLowerCase().includes(searchTerm));

        if(filtered.length === 0) {
            listDiv.innerHTML = '<div style="color:#7f8c8d; text-align:center; font-size:14px; margin-top:10px;">Ingen produkter funnet</div>';
            return;
        }

        filtered.forEach(p => {
            listDiv.innerHTML += `
                <div class="product-item">
                    <div class="prod-info">
                        <span class="prod-name">${p.name}</span>
                        <span class="prod-url">${p.url}</span>
                    </div>
                    <div class="prod-price">${p.price} kr</div>
                    <button class="delete-btn" onclick="deleteProduct(${p.id})">Slett</button>
                </div>
            `;
        });
    }

    // عرض المنتجات فور فتح التطبيق
    displayProducts();
</script>

</body>
</html>
